{
  "name": "devdash-worker",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "staging": "node scripts/seed-local.mjs && wrangler dev --persist-to .wrangler/state",
    "staging:seed": "node scripts/seed-local.mjs",
    "staging:code": "node scripts/seed-local.mjs --code-only"
  },
  "dependencies": {
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  }
}
